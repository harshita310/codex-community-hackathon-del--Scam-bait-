# API Configuration
API_KEY=your_secure_api_key_here

# OpenAI
OPENAI_API_KEY=sk-proj-...
LLM_MODEL=gpt-5.4
OPENAI_DETECTION_MODEL=gpt-5.4-mini
OPENAI_EXTRACTION_MODEL=gpt-5.4
WHISPER_MODEL=gpt-4o-transcribe
TTS_MODEL=gpt-4o-mini-tts
TTS_VOICE=nova
OPENAI_EMBEDDING_MODEL=text-embedding-3-small
OPENAI_VISION_MODEL=gpt-5.4
OPENAI_REALTIME_MODEL=gpt-realtime

# Telegram Bot Configuration
TELEGRAM_BOT_TOKEN=your_existing_token
HONEYPOT_API_URL=http://localhost:8000/api/v1/honeypot

# Twilio Voice Configuration
TWILIO_ACCOUNT_SID=your_existing_sid
TWILIO_AUTH_TOKEN=your_existing_token
TWILIO_PHONE_NUMBER=your_existing_number

# Database / callbacks
DATABASE_URL=sqlite:///honeypot.db
_CALLBACK_URL=https://your-callback-endpoint.example.com
